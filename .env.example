# =============================================================================
# CIAR Cars — Environment Configuration
# Copy to .env and adjust values
# =============================================================================

# --- Database (SQLite dev / PostgreSQL production) ---
# SQLite (default development):
DATABASE_URL="file:./db/custom.db"

# PostgreSQL (production — uncomment and set provider in schema.prisma):
# DATABASE_URL="postgresql://user:password@localhost:5432/ciar_cars?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-long-random-string-in-production"

# --- Python Analytics API (optional sidecar) ---
ANALYTICS_API_URL="http://localhost:8001"
INTERNAL_API_KEY="ciar-dev-internal-key"
CIAR_DATABASE_PATH="./db/custom.db"
ANALYTICS_CORS_ORIGINS="http://localhost:3000"

# --- Upload limits ---
MAX_UPLOAD_SIZE_MB=5
